TELEGRAM_BOT_TOKEN=
TELEGRAM_CHANNEL_ID=-1001234567890
TELEGRAM_ADMIN_USER_ID=
GITHUB_TOKEN=
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# Режим: 12 карточек/день = POSTS_PER_RUN=3 × 4 запуска в сутки (Task Scheduler)

POSTS_PER_RUN=3
HYPE_UTILITY_RATIO=70

# Фильтры
MIN_STARS=100
STRICT_NO_LIBS=true
PREFILTER_LIMIT=30
README_SCAN_LIMIT=100

# v5 reads only keys listed in github_radar/config.py (ENV_KNOWN).
# Removed legacy keys: EXCLUDE_LISTS, STRICT_TOOLS_ONLY — no effect.
# TOPICS: omit to use v5 hype defaults (ai, llm, agent, …) from config.py.
OWNER_BOOSTLIST=apple,google,microsoft,nvidia,openai,anthropic,meta,facebook,vercel,cloudflare,huggingface,mozilla
HOT_TRENDS=ai,agent,agents,llm,claude,gpt,mcp,rag,diffusion,vibe,coding-agent,local-llm,assistant,copilot,voice
MASS_APPEAL_KEYWORDS=windows,macos,mac,ios,android,iphone,browser,chrome,firefox,clipboard,screenshot,wallpaper,phone,desktop,notes,music,photo,video
NICHE_PENALTY_KEYWORDS=kubernetes,helm,terraform,ansible,prometheus,grafana,observability,sysadmin,cron,traceroute,k8s
TOPICS=ai,llm,agent,productivity,macos,windows,android,browser,desktop,app,self-hosted

DB_PATH=./data/radar.sqlite
LOG_PATH=./data/radar.log

# Instagram collectible cards (v5)
MAKE_SLIDES=true
SLIDE_FORMATS=carousel,reels
# Telegram: carousel PNG + одна строка + ссылка (основной режим)
TELEGRAM_CARD_MODE=true
# Classic README+text posts (muted — keep false)
TELEGRAM_CLASSIC_POSTS=false
SLIDE_DIR=./data/instagram
# Часовой пояс для папок карточек и «постов сегодня» (IANA, напр. Europe/Moscow)
TIMEZONE=Europe/Moscow
TEMPLATES_DIR=./templates
BRAND_NAME=Золото GitHub
BRAND_HANDLE=@github_gold
BRAND_TAGLINE=Хороший код — как золото
FRAME_GOLD=#D9B65A
PAPER_BG=#F2EDE2
RARITY_THRESHOLDS=2,4,7,10

# Рубрика «Дичь» (джокер-карта 1×/день)
WEIRD_ENABLED=true
WEIRD_PER_DAY=1
WEIRD_RESERVE_TARGET=10
WEIRD_ACCENT=#FF3D9A
WEIRD_BADGE=ДИЧЬ
WEIRD_TOPICS=fun,joke,useless,silly,meme,for-fun,cursed,art,creative-coding,generative,toy,ascii,esoteric,desktop-pet
